# Ant Gravity Backend Environment Example
# 절대 실제 키를 커밋하지 마.

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Supabase (Server side only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me

# AI Provider
GEMINI_API_KEY=replace-me

# Payment / Billing
PORTONE_SECRET_KEY=replace-me

# Data Source
YFINANCE_CACHE_TTL_MINUTES=30
ALPHA_VANTAGE_API_KEY=replace-me

# Proxy (dev-safe default for market data APIs)
DISABLE_SYSTEM_PROXY_FOR_MARKET_DATA=true
NO_PROXY=localhost,127.0.0.1
